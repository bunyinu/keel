{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "/home/lus/.local/bin/keel hook post-compact --agent codex",
            "statusMessage": "Keel: restoring state after compaction",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/home/lus/.local/bin/keel hook post-tool-use --agent codex",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/home/lus/.local/bin/keel hook pre-compact --agent codex",
            "statusMessage": "Keel: saving state before compaction",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/home/lus/.local/bin/keel hook pre-tool-use --agent codex",
            "statusMessage": "Keel: checking retry loop",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/home/lus/.local/bin/keel hook session-start --agent codex",
            "statusMessage": "Keel: loading session state",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/home/lus/.local/bin/keel hook user-prompt-submit --agent codex",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
